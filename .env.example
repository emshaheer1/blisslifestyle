# Server
PORT=8000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/bliss_lifestyle?appName=Cluster0

# Security — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=8h

# Admin credentials (used by seed script — run once after deploy)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisSecurePassword123!

# CORS — your IONOS site URL(s), comma-separated (no trailing slash)
ALLOWED_ORIGINS=https://blisslifestyle.com,https://www.blisslifestyle.com

# Your Render service URL (dashboard lives here too)
DASHBOARD_URL=https://YOUR-APP-NAME.onrender.com
